# ===== Linux daemon =====
daemon/** text eol=lf
daemon/**/*.sh text eol=lf
daemon/**/*.service text eol=lf
daemon/packaging/debian/** text eol=lf

# ===== Rust =====
*.rs text eol=lf
Cargo.toml text eol=lf
Cargo.lock text eol=lf

# ===== Web / JS / TS (safe with LF) =====
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# ===== Windows specific =====
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ===== Binary files =====
*.png binary
*.jpg binary
*.ico binary
*.exe binary
*.dll binary
*.deb binary