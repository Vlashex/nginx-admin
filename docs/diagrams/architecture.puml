@startuml
skinparam monochrome true
skinparam shadowing false
skinparam componentStyle rectangle

title nginx-admin Control Plane Architecture

package "Clients" {
  [Web UI]
  [Desktop UI]
  [CLI]
}

package "Control Plane" {
  [API Gateway]
  [State Service]
  [Renderer]
  [Apply Transaction Manager]
  [Backup Manager]
  [Reconcile Loop]
}

database "state.json\n/etc/nginx-admin/state.json" as STATE
folder "generated\n/etc/nginx-admin/generated" as GENERATED
folder "legacy\n/etc/nginx-admin/legacy" as LEGACY
folder "backups\n/var/lib/nginx-admin/backups" as BACKUPS

node "Data Plane Host" {
  [NGINX Runtime]
  folder "/etc/nginx" as ETCNGINX
}

[Web UI] --> [API Gateway]
[Desktop UI] --> [API Gateway]
[CLI] --> [API Gateway]

[API Gateway] --> [State Service]
[State Service] --> STATE
[State Service] --> [Renderer]
[Renderer] --> GENERATED
[Apply Transaction Manager] --> GENERATED
[Apply Transaction Manager] --> [Backup Manager]
[Backup Manager] --> BACKUPS
[Apply Transaction Manager] --> ETCNGINX
[Apply Transaction Manager] --> [NGINX Runtime]
[Reconcile Loop] --> STATE
[Reconcile Loop] --> ETCNGINX
[Reconcile Loop] --> [Apply Transaction Manager]

LEGACY ..> [Apply Transaction Manager] : migration input
ETCNGINX --> [NGINX Runtime]
@enduml
