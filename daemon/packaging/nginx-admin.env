# nginx-admin daemon environment
# DAEMON_UNIX_SOCKET_PATH=/run/nginx-admin.sock
# DAEMON_SOCKET_GROUP=www-data
# DAEMON_NGINX_API_CONF_PATH=/etc/nginx/snippets/nginx-admin-location.conf
# DAEMON_NGINX_SERVER_CONF_PATH=/etc/nginx/sites-enabled/default
# DAEMON_STATE_PATH=/etc/nginx-admin/state.json
# DAEMON_BACKUPS_DIR=/var/lib/nginx-admin/backups
# DAEMON_STAGING_DIR=/etc/nginx-admin/staging
# DAEMON_RUNTIME_OUTPUT_DIR=/etc/nginx-admin/generated/runtime
# DAEMON_NGINX_TEST_CMD=nginx -t -c {staging_conf}
# DAEMON_RELOAD_CMD=nginx -s reload
# DAEMON_RECONCILE_INTERVAL_SECS=2
# DAEMON_DRY_RUN=false

