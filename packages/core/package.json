{
  "name": "@vlashex/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./domain/Route": {
      "types": "./dist/domain/Route.d.ts",
      "default": "./dist/domain/Route.js"
    },
    "./ports/RouteGateway": {
      "types": "./dist/ports/RouteGateway.d.ts",
      "default": "./dist/ports/RouteGateway.js"
    },
    "./useCases/remoteRoutes": {
      "types": "./dist/useCases/remoteRoutes.d.ts",
      "default": "./dist/useCases/remoteRoutes.js"
    },
    "./entities/types": {
      "types": "./dist/entities/types.d.ts",
      "default": "./dist/entities/types.js"
    },
    "./useCases/routes": {
      "types": "./dist/useCases/routes.d.ts",
      "default": "./dist/useCases/routes.js"
    },
    "./repositories/RouteRepository": {
      "types": "./dist/repositories/RouteRepository.d.ts",
      "default": "./dist/repositories/RouteRepository.js"
    },
    "./services/ConfigGenerator": {
      "types": "./dist/services/ConfigGenerator.d.ts",
      "default": "./dist/services/ConfigGenerator.js"
    },
    "./services/IntegrationService": {
      "types": "./dist/services/IntegrationService.d.ts",
      "default": "./dist/services/IntegrationService.js"
    },
    "./security/secrets": {
      "types": "./dist/security/secrets.d.ts",
      "default": "./dist/security/secrets.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
