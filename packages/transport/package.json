{
  "name": "@vlashex/transport",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.js", "default": "./dist/index.js" },
    "./RemoteExecutor": { "types": "./dist/RemoteExecutor.d.ts", "import": "./dist/RemoteExecutor.js", "require": "./dist/RemoteExecutor.js", "default": "./dist/RemoteExecutor.js" },
    "./ipc": { "types": "./dist/ipc.d.ts", "import": "./dist/ipc.js", "require": "./dist/ipc.js", "default": "./dist/ipc.js" },
    "./contracts/routeCommands": { "types": "./dist/contracts/routeCommands.d.ts", "import": "./dist/contracts/routeCommands.js", "require": "./dist/contracts/routeCommands.js", "default": "./dist/contracts/routeCommands.js" },
    "./contracts/bootstrap": { "types": "./dist/contracts/bootstrap.d.ts", "import": "./dist/contracts/bootstrap.js", "require": "./dist/contracts/bootstrap.js", "default": "./dist/contracts/bootstrap.js" }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@vlashex/core": "workspace:*"
  }
}
