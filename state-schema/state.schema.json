{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nginx-admin.local/state.schema.json",
  "title": "nginx-admin Control Plane State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "revision",
    "updatedAt",
    "updatedBy",
    "servers"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "servers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/server"
      }
    }
  },
  "$defs": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "serverName",
        "listen",
        "routes",
        "enabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._:-]{1,128}$"
        },
        "serverName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253
        },
        "listen": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/listen"
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "tls": {
          "$ref": "#/$defs/tls"
        },
        "extraDirectives": {
          "type": "array",
          "items": {
            "type": "string",
            "not": {
              "pattern": "([Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Jj][Ww][Tt]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn])"
            }
          }
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "listen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "port",
        "ssl"
      ],
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "ssl": {
          "type": "boolean"
        },
        "http2": {
          "type": "boolean",
          "default": false
        },
        "defaultServer": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certificate",
        "certificateKey"
      ],
      "properties": {
        "certificate": {
          "type": "string",
          "pattern": "^/.*"
        },
        "certificateKey": {
          "type": "string",
          "pattern": "^/.*"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "action",
        "enabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._:-]{1,128}$"
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "matchType": {
          "type": "string",
          "enum": [
            "prefix",
            "exact",
            "regex"
          ],
          "default": "prefix"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "headers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/header"
          }
        },
        "rateLimit": {
          "$ref": "#/$defs/rateLimit"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "action": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "target"
          ],
          "properties": {
            "type": {
              "const": "proxy_pass"
            },
            "target": {
              "type": "string",
              "pattern": "^(https?://[^/@?#]+(:[0-9]+)?(/.*)?|http://unix:.+)$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "root"
          ],
          "properties": {
            "type": {
              "const": "static"
            },
            "root": {
              "type": "string",
              "pattern": "^/.*"
            },
            "index": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "url",
            "code"
          ],
          "properties": {
            "type": {
              "const": "redirect"
            },
            "url": {
              "type": "string"
            },
            "code": {
              "type": "integer",
              "enum": [
                301,
                302,
                307,
                308
              ]
            }
          }
        }
      ]
    },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "([Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Aa][Ss][Ss][Pp][Hh][Rr][Aa][Ss][Ee]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee]|[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Kk][Ee][Yy]|[Jj][Ww][Tt]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee])"
          }
        },
        "value": {
          "type": "string"
        }
      }
    },
    "rateLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone",
        "rate"
      ],
      "properties": {
        "zone": {
          "type": "string"
        },
        "rate": {
          "type": "string",
          "pattern": "^[0-9]+r/[smh]$"
        },
        "burst": {
          "type": "integer",
          "minimum": 0
        },
        "nodelay": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
